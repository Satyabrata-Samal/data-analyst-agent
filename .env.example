# Anthropic API Configuration
# Copy this file to `.env` and fill in your key. Never commit real keys.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model Configuration
MODEL_NAME=claude-sonnet-4-6
MAX_TOKENS=4096
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0
LLM_TIMEOUT_SECONDS=60

# Data Validation Limits
MAX_FILE_SIZE_MB=50.0
MAX_ROW_COUNT=500000
MAX_COLUMN_COUNT=200
SAMPLE_SIZE=50000
SAMPLE_THRESHOLD=100000

# Code Execution Limits
CODE_EXECUTION_TIMEOUT=30
MAX_STDOUT_BYTES=8192
MAX_CRITIQUE_ITERATIONS=2
CRITIQUE_APPROVAL_THRESHOLD=7.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=agent_run.log
